<UserControl x:Class="Shed_Security_AP.Views.WorldControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Minimal dark slider thumb -->
        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource AccentBrush}"
                                 Width="16" Height="16" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4"
                                    VerticalAlignment="Center"
                                    Background="#2A2A3A"
                                    CornerRadius="2" />
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}"
                                           Cursor="Hand" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════ Header ════════════════════ -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,14">
            <TextBlock Text="&#xE706;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="18"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <TextBlock Text="World Control"
                       Style="{StaticResource HeaderStyle}"
                       FontSize="20" />
        </StackPanel>

        <!-- ════════════════════ Metric Cards ════════════════════ -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,14">

            <!-- Time of Day Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TIME OF DAY"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding TimeDisplay}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="28"
                               FontWeight="Bold"
                               FontFamily="Cascadia Mono, Consolas, Courier New" />
                </StackPanel>
            </Border>

            <!-- Season Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="4,0,4,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="SEASON"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding Season}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="28"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>

            <!-- Storm Status Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TEMPORAL STORM"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding StormStatus}"
                               Foreground="#E06C75"
                               FontSize="28"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ════════════════════ Time Slider ════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16"
                Margin="0,0,0,14">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="SET TIME OF DAY"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SliderTimeLabel}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="Cascadia Mono, Consolas, Courier New"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider Grid.Column="0"
                            Style="{StaticResource DarkSlider}"
                            Minimum="0" Maximum="24"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            Value="{Binding SliderHour, Mode=TwoWay}"
                            VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Command="{Binding SetTimeCommand}"
                            Style="{StaticResource AccentButton}"
                            Content="Set"
                            Padding="20,6"
                            FontSize="12"
                            Margin="14,0,0,0" />
                </Grid>

                <!-- Hour markers -->
                <Grid Margin="8,4,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="1" Text="6"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="2" Text="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="3" Text="18"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="3" Text="24"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9" HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ════════════════════ Action Buttons ════════════════════ -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="2"
                     VerticalAlignment="Top"
                     Margin="0,0,0,14">

            <!-- Skip Night -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE706;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="28"
                               Foreground="#10B981"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Skip to morning (06:00)"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <Button Command="{Binding SkipNightCommand}"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="#10B981"
                                                    CornerRadius="6"
                                                    Padding="20,0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0D9668" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A7B54" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Skip Night" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Force Temporal Storm -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE945;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="28"
                               Foreground="#E11D48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Trigger or cancel a storm"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding ForceStormCommand}"
                                Height="40"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="#E11D48"
                                                        CornerRadius="6"
                                                        Padding="16,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#C4183E" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#A11434" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Force Storm" />
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding StopStormCommand}"
                                Style="{StaticResource AccentButton}"
                                Height="40"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Content="Cancel Storm" />
                    </Grid>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ════════════════════ Status Bar ════════════════════ -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11"
                   Margin="0,4,0,0" />
    </Grid>
</UserControl>
