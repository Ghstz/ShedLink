<UserControl x:Class="Shed_Security_AP.Views.ConfigEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header & Buttons -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left">
                <TextBlock Text="&#xE943;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="18"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Text="Server Configuration"
                           Style="{StaticResource HeaderStyle}"
                           FontSize="20"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <ComboBox Style="{StaticResource ModernComboBox}"
                          ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                          ItemsSource="{Binding AvailableConfigs}"
                          SelectedItem="{Binding SelectedConfig}"
                          Width="200"
                          Height="34"
                          Margin="0,0,10,0" />
                <Button Content="Save Config"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding SaveConfigCommand}"
                        Height="34"
                        FontSize="12"
                        Padding="16,0" />
            </StackPanel>
        </DockPanel>

        <!-- JSON Editor Card -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <TextBlock Text="&#xE70F;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="CONFIG EDITOR"
                               Style="{StaticResource LabelStyle}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBox Text="{Binding ConfigJson, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             FontFamily="Cascadia Mono, Consolas, Courier New"
                             FontSize="13"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                             BorderThickness="0"
                             Padding="16,12" />
                </Border>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="⏳"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <TextBlock Text="Working..."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
