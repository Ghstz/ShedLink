<UserControl x:Class="Shed_Security_AP.Views.AntiCheatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ════════════════════ Live Alerts ════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <TextBlock Text="&#xEA39;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Live Alerts"
                               Style="{StaticResource HeaderStyle}"
                               FontSize="16" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LiveAlerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="6"
                                        Padding="12,10"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Alert Type Badge -->
                                        <Border x:Name="AlertBadge"
                                                Grid.Column="0" Grid.Row="0"
                                                Background="{StaticResource BorderSubtleBrush}"
                                                CornerRadius="3"
                                                Padding="6,2"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="AlertBadgeText"
                                                       Text="{Binding AlertType}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                        </Border>

                                        <!-- Player Name -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding PlayerName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />

                                        <!-- Strike Count -->
                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0">
                                            <Run Text="×" /><Run Text="{Binding StrikeCount, Mode=OneWay}" />
                                        </TextBlock>

                                        <!-- Timestamp -->
                                        <TextBlock Grid.Column="3" Grid.Row="0"
                                                   Text="{Binding Timestamp}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center" />

                                        <!-- Details -->
                                        <TextBlock Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="1"
                                                   Text="{Binding Details}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding PlayerName}" Value="System">
                                        <Setter TargetName="AlertBadge" Property="Background" Value="#FF2A2D3A" />
                                        <Setter TargetName="AlertBadgeText" Property="Foreground" Value="#FF6B8ADB" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ════════════════════ Shadowbanned Players ════════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2" Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <TextBlock Text="&#xE8F8;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Shadowbanned Players"
                               Style="{StaticResource HeaderStyle}"
                               FontSize="16" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ShadowbannedPlayers}"
                                  x:Name="ShadowbanList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="6"
                                        Padding="12,10"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />

                                        <Button Grid.Column="1"
                                                Content="Pardon"
                                                Command="{Binding DataContext.PardonPlayerCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource AccentButton}"
                                                Height="28"
                                                FontSize="11"
                                                Width="60"
                                                Padding="0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
