<UserControl x:Class="Shed_Security_AP.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:Shed_Security_AP.Core"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid>
        <!-- Floating login card -->
        <Border Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="32,24"
                Width="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="0,10">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="20"
                                  Opacity="0.3"
                                  Direction="270"
                                  ShadowDepth="4" />
            </Border.Effect>

            <StackPanel>

                <!-- ── Header ── -->
                <TextBlock Text="🔌"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="Connect to Server"
                           Style="{StaticResource HeaderStyle}"
                           FontSize="20"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enter your Vintage Story server details"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,18" />

                <!-- ── Saved Profiles ── -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SAVED PROFILES"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding SavedProfiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              Style="{StaticResource ModernComboBox}"
                              ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- ── Server IP ── -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SERVER IP"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,0,0,4" />
                    <TextBox Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" />
                </StackPanel>

                <!-- ── Port ── -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="PORT"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,0,0,4" />
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" />
                </StackPanel>

                <!-- ── Security Token ── -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SECURITY TOKEN"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,0,0,4" />
                    <PasswordBox Style="{StaticResource ModernPasswordBox}"
                                 core:PasswordBoxHelper.Attach="True"
                                 core:PasswordBoxHelper.BoundPassword="{Binding SecurityToken, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                </StackPanel>

                <!-- ── Save Profile Button ── -->
                <Button Content="Save Profile"
                        Command="{Binding SaveProfileCommand}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12"
                        Cursor="Hand"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,18">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="Txt"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextDecorations="Underline" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Txt" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- ── Error Message ── -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FFE53935"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- ── Connect Button ── -->
                <Button Content="Connect"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource AccentButton}" />

                <!-- ── Connecting indicator ── -->
                <TextBlock Text="Connecting..."
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
