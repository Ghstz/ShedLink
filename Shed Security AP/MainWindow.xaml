<Window x:Class="Shed_Security_AP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Shed_Security_AP.ViewModels"
        xmlns:views="clr-namespace:Shed_Security_AP.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="650" Width="1100"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <views:ConnectionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AntiCheatViewModel}">
            <views:AntiCheatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigEditorViewModel}">
            <views:ConfigEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModManagerViewModel}">
            <views:ModManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupManagerViewModel}">
            <views:BackupManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
            <views:DiagnosticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SpawnerViewModel}">
            <views:SpawnerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccessControlViewModel}">
            <views:AccessControlView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RadarViewModel}">
            <views:RadarView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorldControlViewModel}">
            <views:WorldControlView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NavigationViewModel}">
            <views:NavigationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AppSettingsViewModel}">
            <views:AppSettingsView />
        </DataTemplate>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BackgroundDarkBrush}"
            CornerRadius="10"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            TextElement.FontFamily="{DynamicResource AppFont}"
            TextElement.Foreground="{StaticResource TextPrimaryBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BackgroundMediumBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text="🔗"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <!-- Minimize -->
                    <Button Command="{Binding MinimizeCommand}"
                            Style="{StaticResource WindowControlButton}"
                            ToolTip="Minimize">
                        <TextBlock Text="—" FontSize="12" />
                    </Button>

                    <!-- Maximize / Restore -->
                    <Button Command="{Binding MaximizeRestoreCommand}"
                            Style="{StaticResource WindowControlButton}"
                            ToolTip="Maximize">
                        <TextBlock Text="☐" FontSize="13" />
                    </Button>

                    <!-- Close -->
                    <Button Command="{Binding CloseCommand}"
                            Style="{StaticResource WindowCloseButton}"
                            ToolTip="Close">
                        <TextBlock Text="✕" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundMediumBrush}"
                        CornerRadius="0,0,0,10">
                    <DockPanel>
                        <!-- Bottom status area -->
                        <StackPanel DockPanel.Dock="Bottom"
                                    Margin="8,0,8,12">
                            <Separator Background="{StaticResource BorderSubtleBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <!-- Navigation menu -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Style="{StaticResource FadeScrollViewer}">
                        <StackPanel Margin="0,8,0,0"
                                    HorizontalAlignment="Center">
                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         IsChecked="True"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Connection">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8BA;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Connect"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Dashboard">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9D9;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Dashboard"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="AntiCheat">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xEA18;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Anti-Cheat"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="ConfigEditor">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE943;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Config"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="ModManager">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE74C;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Mods"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="BackupManager">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE753;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Backups"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Diagnostics">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9F9;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Diagnostics"
                                               FontSize="11"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Spawner">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE7B8;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Spawner"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="AccessControl">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE72E;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Access"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Radar">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE909;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Radar"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="WorldControl">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE706;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="World"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Navigation">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE707;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Navigate"
                                               FontSize="11"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="History">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE81C;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="History"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Nav"
                                         Style="{StaticResource SidebarMenuButton}"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="AppSettings">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE713;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Settings"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Content Area -->
                <Border Grid.Column="1"
                        Background="{StaticResource BackgroundDarkBrush}"
                        CornerRadius="0,0,10,0"
                        Margin="0,0,1,1">
                    <ContentControl Content="{Binding CurrentView}" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
